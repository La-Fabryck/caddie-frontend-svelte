{
	"name": "caddie-frontend-svelte",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"scripts": {
		"dev": "concurrently -n \"VITE,SVELTE-CHECK\" -c \"blue,green\" \"npm run dev:vite\" \"npm run dev:watch\"",
		"dev:vite": "vite dev",
		"dev:watch": "npm run check -- --watch",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"format": "npm run format:svelte && npm run format:eslint",
		"format:svelte": "prettier --write \"**/*.svelte\"",
		"format:eslint": "eslint --fix .",
		"lint": "npm run lint:svelte && npm run lint:eslint",
		"lint:svelte": "prettier --check \"**/*.svelte\"",
		"lint:eslint": "eslint .",
		"test": "npm run test:unit -- --run"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.5",
		"@eslint/js": "^10.0.1",
		"@internationalized/date": "^3.12.1",
		"@lucide/svelte": "^1.9.0",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.57.1",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.4",
		"@types/node": "^24",
		"@typescript-eslint/parser": "^8.59.0",
		"@vitest/browser-playwright": "^4.1.5",
		"bits-ui": "^2.18.0",
		"clsx": "^2.1.1",
		"concurrently": "^9.2.1",
		"eslint": "^10.2.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-prettier": "^5.5.5",
		"eslint-plugin-svelte": "^3.17.1",
		"formsnap": "^2.0.1",
		"globals": "^17.5.0",
		"playwright": "^1.59.1",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.3",
		"svelte": "^5.55.4",
		"svelte-check": "^4.4.6",
		"sveltekit-superforms": "^2.30.1",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.2.4",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.0",
		"vite": "^8.0.10",
		"vitest": "^4.1.5",
		"vitest-browser-svelte": "^2.1.1"
	}
}
