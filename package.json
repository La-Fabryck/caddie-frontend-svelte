{
	"name": "caddie-frontend-svelte",
	"version": "0.2.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "concurrently -n \"VITE,SVELTE-CHECK\" -c \"blue,green\" \"npm run dev:vite\" \"npm run dev:watch\"",
		"dev:vite": "vite dev",
		"dev:watch": "npm run check -- --watch",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo '' && husky",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"format": "oxfmt --write . && eslint --fix .",
		"lint": "oxfmt --check . && eslint .",
		"test": "npm run test:unit -- --run"
	},
	"devDependencies": {
		"@eslint/compat": "^2.1.0",
		"@eslint/js": "^10.0.1",
		"@internationalized/date": "^3.12.1",
		"@lucide/svelte": "^1.16.0",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.60.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.0",
		"@types/node": "^24",
		"@typescript-eslint/parser": "^8.59.4",
		"@vitest/browser-playwright": "^4.1.6",
		"bits-ui": "^2.18.1",
		"clsx": "^2.1.1",
		"concurrently": "^9.2.1",
		"eslint": "^10.4.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.1",
		"formsnap": "^2.0.1",
		"globals": "^17.6.0",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.5",
		"oxfmt": "^0.50.0",
		"playwright": "^1.60.0",
		"svelte": "^5.55.8",
		"svelte-check": "^4.4.8",
		"sveltekit-superforms": "^2.30.1",
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.3.0",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.4",
		"vite": "^8.0.13",
		"vitest": "^4.1.6",
		"vitest-browser-svelte": "^2.1.1"
	},
	"lint-staged": {
		"*.{js,ts,svelte}": [
			"oxfmt --write",
			"eslint --fix"
		],
		"*.{json,css,md,html,yml,yaml}": "oxfmt --write"
	},
	"engines": {
		"node": ">=24"
	}
}
